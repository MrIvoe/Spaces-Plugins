{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Spaces-Plugins/plugin-manifest.schema.json",
  "title": "SimpleFences Plugin Manifest",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "version",
    "description",
    "author",
    "enabledByDefault",
    "supportsSettingsPage",
    "supportsMainContentPage",
    "supportsHostedSummaryPanel",
    "icon",
    "updateChannelId",
    "hostedSummaryPanel",
    "capabilities",
    "repository"
  ],
  "oneOf": [
    {
      "required": [
        "minHostVersion",
        "maxHostVersion",
        "minHostApiVersion",
        "maxHostApiVersion"
      ]
    },
    {
      "required": [
        "compatibility"
      ]
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^community\\.[a-z0-9_]+$"
    },
    "displayName": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "minHostVersion": { "type": "string", "minLength": 1 },
    "maxHostVersion": { "type": "string", "minLength": 1 },
    "minHostApiVersion": { "type": "string", "minLength": 1 },
    "maxHostApiVersion": { "type": "string", "minLength": 1 },
    "compatibility": {
      "type": "object",
      "required": ["hostVersion", "hostApiVersion"],
      "properties": {
        "hostVersion": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "max": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            }
          },
          "additionalProperties": false
        },
        "hostApiVersion": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "max": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "enabledByDefault": { "type": "boolean" },
    "supportsSettingsPage": { "type": "boolean" },
    "supportsMainContentPage": { "type": "boolean" },
    "supportsHostedSummaryPanel": { "type": "boolean" },
    "icon": { "type": "string" },
    "updateChannelId": { "type": "string", "enum": ["stable", "preview"] },
    "hostedSummaryPanel": {
      "type": "object",
      "required": ["panelId", "title", "schemaVersion", "layout", "themeTokenNamespace", "sections"],
      "properties": {
        "panelId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "schemaVersion": { "type": "string", "const": "1" },
        "layout": { "type": "string", "enum": ["cards", "sections", "compact"] },
        "themeTokenNamespace": { "type": "string", "const": "win32_theme_system" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "title", "description", "iconToken", "surfaceToken"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "iconToken": { "type": "string", "minLength": 1 },
              "surfaceToken": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "read_fence_metadata",
          "write_fence_settings",
          "read_settings",
          "write_settings",
          "network_access",
          "filesystem_read",
          "filesystem_write",
          "execute_host_commands"
        ]
      }
    },
    "repository": { "type": "string", "format": "uri" }
  },
  "additionalProperties": false
}
