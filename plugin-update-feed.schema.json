{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Simple-Fences-Plugins/plugin-update-feed.schema.json",
  "title": "SimpleFences Plugin Update Feed",
  "type": "object",
  "required": ["schemaVersion", "generatedAtUtc", "channel", "plugins"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "channel": {
      "type": "string",
      "minLength": 1
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pluginId",
          "displayName",
          "version",
          "author",
          "description",
          "minHostVersion",
          "maxHostVersion",
          "minHostApiVersion",
          "maxHostApiVersion",
          "packageUrl",
          "sha256",
          "updateChannelId"
        ],
        "properties": {
          "pluginId": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "author": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "minHostVersion": { "type": "string", "minLength": 1 },
          "maxHostVersion": { "type": "string", "minLength": 1 },
          "minHostApiVersion": { "type": "string", "minLength": 1 },
          "maxHostApiVersion": { "type": "string", "minLength": 1 },
          "packageUrl": { "type": "string", "format": "uri" },
          "sha256": { "type": "string", "minLength": 64, "maxLength": 128 },
          "packageSizeBytes": { "type": "integer", "minimum": 0 },
          "updateChannelId": { "type": "string", "minLength": 1 },
          "releaseNotesUrl": { "type": "string", "format": "uri" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
