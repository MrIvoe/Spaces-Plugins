{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simplefences.dev/schemas/rules-engine/rules.schema.json",
  "title": "SimpleFences Rules Engine Rule Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "rules"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evalMode": {
          "type": "string",
          "enum": ["first_match", "all_matches", "first_terminal_match"]
        },
        "dryRun": {
          "type": "boolean"
        },
        "maxRulesPerItem": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "preventLoops": {
          "type": "boolean"
        },
        "debounceMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 600000
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "priority",
        "match",
        "actions"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9_.-]+$"
        },
        "enabled": {
          "type": "boolean"
        },
        "priority": {
          "type": "integer",
          "minimum": -100000,
          "maximum": 100000
        },
        "stopProcessing": {
          "type": "boolean",
          "default": false
        },
        "match": {
          "$ref": "#/$defs/match"
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/action"
          }
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nameRegex": {
          "type": "string"
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+$"
          }
        },
        "isDirectory": {
          "type": "boolean"
        },
        "sourceFenceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "route_to_group",
            "move_to_fence",
            "tag",
            "set_priority",
            "run_command"
          ]
        },
        "group": {
          "type": "string"
        },
        "fenceId": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "priority": {
          "type": "integer"
        },
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
